rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // User validation helper
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.role is string && data.role.size() <= 32;
    }
    
    // Match definitions
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if true;
    }
    
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    match /commissions/{commissionId} {
      allow read, write: if true;
    }
    
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }

    match /brandAudits/{auditId} {
      allow read, write: if true;
    }

    match /sponsorships/{sponsorshipId} {
      allow read, write: if true;
    }

    match /subscribers/{subscriberId} {
      allow read, write: if true;
    }

    match /enrollments/{enrollmentId} {
      allow read, write: if true;
    }

    match /announcements/{announcementId} {
      allow read, write: if true;
    }

    match /mentorshipRequests/{requestId} {
      allow read, write: if true;
    }

    match /utmLinks/{linkId} {
      allow read, write: if true;
    }
  }
}
